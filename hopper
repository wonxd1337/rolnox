-- Fungsi untuk minimize/maximize GUI
local function toggleMinimize()
    isMinimized = not isMinimized
    
    if isMinimized then
        MinimizeButton.Text = "+"
        Content.Visible = false
        MainFrame.Size = minimizedSize
    else
        MinimizeButton.Text = "-"
        Content.Visible = true
        MainFrame.Size = originalSize
    end
end

-- SISTEM DRAGABLE YANG DIPERBAIKI
local dragging = false
local dragStartPos = Vector2.new(0, 0)
local frameStartPos = UDim2.new(0, 0, 0, 0)

-- Fungsi untuk mulai drag
local function startDrag()
    dragging = true
    dragStartPos = UserInputService:GetMouseLocation()
    frameStartPos = MainFrame.Position
end

-- Fungsi untuk stop drag
local function stopDrag()
    dragging = false
end

-- Fungsi untuk update posisi saat drag
local function updateDrag()
    if not dragging then return end
    
    local mousePos = UserInputService:GetMouseLocation()
    local delta = mousePos - dragStartPos
    
    local newX = frameStartPos.X.Offset + delta.X
    local newY = frameStartPos.Y.Offset + delta.Y
    
    -- Batasi agar tidak keluar dari layar
    local viewportSize = workspace.CurrentCamera.ViewportSize
    local frameSize = MainFrame.AbsoluteSize
    
    newX = math.clamp(newX, 0, viewportSize.X - frameSize.X)
    newY = math.clamp(newY, 0, viewportSize.Y - frameSize.Y)
    
    MainFrame.Position = UDim2.new(0, newX, 0, newY)
end

-- Event untuk drag pada header
