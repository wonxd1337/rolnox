-- Fungsi untuk refresh server list
local function refreshServerList()
    -- Clear existing servers
    for _, child in ipairs(ServersFrame:GetChildren()) do
        if child:IsA("Frame") and child.Name:sub(1, 6) == "Server" then
            child:Destroy()
        end
    end
    
    LoadingLabel.Visible = true
    RefreshButton.Text = "LOADING..."
    
    -- Mengambil data server
    task.spawn(function()
        local allServers = {}
        local cursor = ""
        
        -- Mengambil beberapa halaman server
        for i = 1, 3 do
            local serverData = getServers(placeId, cursor)
            
            if serverData and serverData.data then
                for _, server in ipairs(serverData.data) do
                    table.insert(allServers, server)
                end
                
                cursor = serverData.nextPageCursor or ""
                if cursor == "" then break end
            else
                break
            end
        end
        
        -- Mengurutkan berdasarkan jumlah pemain (terbanyak dulu)
        table.sort(allServers, function(a, b)
            return a.playing > b.playing
        end)
        
        -- Membuat tombol untuk setiap server
        for i, server in ipairs(allServers) do
            if i <= 20 then  -- Batasi hingga 20 server untuk performa
                local serverButton = createServerButton(server, i)
                serverButton.Parent = ServersFrame
                task.wait()
            end
        end
        
        LoadingLabel.Visible = false
        RefreshButton.Text = "REFRESH SERVERS"
        
        if #allServers == 0 then
            local NoServers = Instance.new("TextLabel")
            NoServers.Name = "NoServers"
            NoServers.Size = UDim2.new(1, 0, 0, 50)
            NoServers.BackgroundTransparency = 1
            NoServers.Text = "No servers found."
            NoServers.TextColor3 = themeColors.secondaryText
            NoServers.Font = Enum.Font.Gotham
            NoServers.TextSize = 14
            NoServers.Parent = ServersFrame
        end
    end)
end

-- Fungsi untuk toggle GUI
local function toggleGUI()
    guiEnabled = not guiEnabled
